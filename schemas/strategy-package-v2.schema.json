{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agtrade.local/schemas/strategy-package-v2.schema.json",
  "title": "Canonical Strategy Package v2 Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "package_format",
    "package_id",
    "strategy_id",
    "strategy_version",
    "adapter_id",
    "adapter_version",
    "symbols",
    "live_trading_enabled",
    "members"
  ],
  "properties": {
    "package_format": {"const": "strategy-package/v2"},
    "package_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "strategy_id": {"type": "string", "minLength": 1},
    "strategy_version": {"type": "string", "minLength": 1},
    "adapter_id": {"type": "string", "minLength": 1},
    "adapter_version": {"type": "string", "minLength": 1},
    "symbols": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "live_trading_enabled": {"const": false},
    "members": {
      "type": "object",
      "minProperties": 6,
      "additionalProperties": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
    }
  }
}
