# Session & SMC Trading Bot — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.

# ── MetaAPI (VT Markets broker connection) ──────────────────────────────────
METAAPI_TOKEN=
METAAPI_ACCOUNT_ID=

# ── Vantage MT5 Demo (ST-A2 demo execution) ──────────────────────────────────
VANTAGE_MT5_DEMO_LOGIN=
VANTAGE_MT5_DEMO_PASSWORD=
VANTAGE_MT5_DEMO_SERVER=
# MetaAPI account UUID for the demo account — get from https://app.metaapi.cloud
# Add demo MT5 credentials there → copy the account UUID → paste below
VANTAGE_DEMO_METAAPI_ID=
DEMO_ONLY=true            # true = log orders, never send. flip to false after checklist passes.

# ── Vantage MT5 Live ──────────────────────────────────────────────────────────
VANTAGE-LIVE=
VANTAGE-LIVE-PASSWORD=
VANTAGE-SERVER=
VANTAGE-LIVE-METAAPI-ID=

# ── MT5 broker credentials (MetaAPI manages the connection; these are for reference) ──
MT5_LOGIN=
MT5_PASSWORD=
# Exness demo server options (check Exness portal for your assigned server):
#   Exness-MT5Trial4  (most common for new demo accounts)
#   Exness-MT5Trial3 / Exness-MT5Trial5 — assigned at registration
# Replace with the server shown in your Exness Personal Area.
MT5_SERVER=Exness-MT5Trial4

# ── Telegram alerts ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Gemini AI (new-dashboard strategy intake and failure diagnosis) ──────────
# Get key from https://aistudio.google.com/app/apikey
# Required for POST /api/new-dashboard/gemini/parse and /gemini/explain-failure
# If unset, those endpoints return 503 — all other dashboard features still work.
GEMINI_API_KEY=

# ── Dashboard / control panel ────────────────────────────────────────────────
# Bind the dashboard to the VPS IP so the control panel is reachable on the
# server's public interface. If unset, the app falls back to 0.0.0.0.
VPS_IP_ADDRESS=
DASHBOARD_HOST=
DASHBOARD_PUBLIC_HOST=
DASHBOARD_PORT=8080
DASHBOARD_SUBPROCESS_TIMEOUT=120  # seconds; max time to wait for SVOS/EVF subprocess runs

# ── Live trading gate ────────────────────────────────────────────────────────
# false = dry run (connect for data only, no orders placed anywhere)
# true  = orders sent to the connected MT5 account (demo or live)
# Owner flips to true ONLY after Phase-0 + 30-day paper trade passes.
LIVE_TRADING=false

# ── Historical data (backtesting) ────────────────────────────────────────────
# No credentials needed — fetch_data.py uses Dukascopy public datafeed.
# Run: python3 scripts/fetch_data.py
# First run downloads ~5yr of M15/H1/H4 for EURUSD+GBPUSD (~60-90 min).
# Subsequent runs are incremental (only missing days).

# ── Research DB runtime mode ─────────────────────────────────────────────────
# DB_BACKEND=postgres   # use PostgreSQL and require localhost:5432
# DB_BACKEND=duckdb     # use local DuckDB / research engine, skip localhost:5432
# DB_BACKEND=sqlite     # use local SQLite, skip localhost:5432
# DB_BACKEND=disabled   # never probe the DB in health checks
# DB_HEALTHCHECK_ENABLED=true
