server {
    listen 443 ssl http2;
    server_name dashboard.example.internal;

    ssl_certificate /etc/letsencrypt/live/dashboard.example.internal/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/dashboard.example.internal/privkey.pem;

    location = /oauth2/auth {
        proxy_pass http://127.0.0.1:4180;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Scheme $scheme;
        proxy_set_header X-Auth-Request-Redirect $request_uri;
    }

    location /oauth2/ {
        proxy_pass http://127.0.0.1:4180;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Scheme $scheme;
    }

    location / {
        auth_request /oauth2/auth;
        error_page 401 = /oauth2/sign_in;

        auth_request_set $dashboard_user $upstream_http_x_auth_request_email;
        auth_request_set $dashboard_groups $upstream_http_x_auth_request_groups;

        proxy_set_header X-Forwarded-Email $dashboard_user;
        proxy_set_header X-SVOS-Proxy-Role "";
        proxy_set_header X-Dashboard-Proxy-Secret ${DASHBOARD_PROXY_SECRET};

        # Strip all client-supplied identity headers before adding trusted values.
        proxy_set_header X-SVOS-Actor "";
        proxy_set_header X-SVOS-Role "";
        proxy_set_header Authorization "";

        # Replace this map logic with your explicit allowlist policy.
        if ($dashboard_user = "admin@example.com") {
            proxy_set_header X-SVOS-Proxy-Role admin;
        }
        if ($dashboard_user = "risk@example.com") {
            proxy_set_header X-SVOS-Proxy-Role risk_operator;
        }
        if ($dashboard_user = "research@example.com") {
            proxy_set_header X-SVOS-Proxy-Role research_operator;
        }

        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
}
