DASHBOARD_PORT=8080
DASHBOARD_BIND_HOST=127.0.0.1
DASHBOARD_PROXY_SECRET=replace-me
DASHBOARD_PROXY_SECRET_HEADER=X-Dashboard-Proxy-Secret
DASHBOARD_PROXY_ACTOR_HEADER=X-Forwarded-Email
DASHBOARD_PROXY_ROLE_HEADER=X-SVOS-Proxy-Role
DASHBOARD_CSRF_COOKIE_NAME=dashboard_csrf
DASHBOARD_CSRF_HEADER_NAME=X-CSRF-Token
DEMO_ONLY=true
LIVE_TRADING=false
