[Unit]
Description=Reconcile broker positions against SQLite trade journal
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=aungp
WorkingDirectory=/opt/session-smc-trading-bot
EnvironmentFile=/etc/session-smc-trading-bot/live-dashboard.env
ExecStart=/opt/session-smc-trading-bot/.venv/bin/python /opt/session-smc-trading-bot/scripts/reconcile_positions.py
