POSTGRES_DB=trading_research
POSTGRES_USER=trading_user
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://trading_user:change-me@127.0.0.1:5432/trading_research
DB_BACKEND=postgres
DB_HEALTHCHECK_ENABLED=true
POSTGRES_BIND_ADDRESS=127.0.0.1
ADMINER_BIND_ADDRESS=127.0.0.1
DEMO_LIVE=false
LIVE_TRADING=false
DEMO_ONLY=true

# Production artifact transport. Keep "mirror" for local rehearsals; a real
# host uses "real" with Application Default Credentials and the IAM roles
# documented in docs/architecture/remaining_real_world_rollout_tasks.md.
SVOS_PACKAGE_TRANSPORT=local
SVOS_CLOUD_ADAPTER=mirror
SVOS_GCS_BUCKET=
SVOS_GCS_PREFIX=strategy-packages
SVOS_GCS_MIRROR_ROOT=
SVOS_PACKAGE_SIGNING_MODE=sha256-attestation
SVOS_KMS_KEY_VERSION=
PRODUCTION_HEARTBEAT_MAX_AGE_SECONDS=120
