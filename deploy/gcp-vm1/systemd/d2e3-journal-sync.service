[Unit]
Description=Sync D2E3 journal to PostgreSQL
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=oneshot
User=aungp
WorkingDirectory=/opt/session-smc-trading-bot
EnvironmentFile=/etc/session-smc-trading-bot/d2e3.env
ExecStart=/opt/session-smc-trading-bot/.venv/bin/python /opt/session-smc-trading-bot/scripts/d2e3_journal_to_db.py --log /opt/session-smc-trading-bot/logs/d2e3_trades.jsonl
